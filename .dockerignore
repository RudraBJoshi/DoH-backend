# Git
.git
.gitignore
.gitattributes

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# Secrets — never bake into image
.env
*.env.*

# Database files (mounted as a volume at runtime)
instance/volumes/*.db
instance/volumes/*.db-wal
instance/volumes/*.db-shm
instance/backup/

# Dev/editor junk
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Test artifacts
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Docs / misc
*.md
LICENSE
